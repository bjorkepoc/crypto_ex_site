#!/bin/sh

msg_file="$1"
msg="$(head -n 1 "$msg_file" | tr -d '\r')"

# Allow standard auto-generated commit messages.
case "$msg" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore)(\([a-z0-9._/-]+\))?(!)?: .+'

if printf '%s' "$msg" | grep -Eq "$pattern"; then
  exit 0
fi

echo "Commit message must follow Conventional Commits." >&2
echo "Example: feat(auth): add token refresh flow" >&2
echo "Allowed types: feat, fix, docs, style, refactor, perf, test, build, ci, chore" >&2
exit 1
